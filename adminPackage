<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة الإدارة - Mahmoud Elmrakby</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>

    <script>
        tailwind.config = {
            theme: { extend: { fontFamily: { sans: ['Tajawal', 'sans-serif'] } } }
        }
    </script>

    <style type="text/tailwindcss">
        body { font-family: 'Tajawal', sans-serif; background-color: #f8fafc; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f5f9; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="text-slate-800">

    <div id="app-root"></div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, collection, doc, setDoc, onSnapshot, getDocs, updateDoc, deleteDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // ============================================================================
        // 🔴 إعدادات قاعدة بيانات فايربيس (نفس إعدادات المنيو) 🔴
        // ============================================================================
        const firebaseConfig = {
          apiKey: "AIzaSyCI0L2fO4_bdltYF7Hddjcxa6seSDbrMwc",
          authDomain: "studio-noot.firebaseapp.com",
          databaseURL: "https://studio-noot-default-rtdb.asia-southeast1.firebasedatabase.app",
          projectId: "studio-noot",
          storageBucket: "studio-noot.firebasestorage.app",
          messagingSenderId: "376391287753",
          appId: "1:376391287753:web:58219ac850bde7e2a79e18"
        };

        window.state = {
            isAuthenticated: false,
            activeTab: 'dashboard', // dashboard, menu
            menuTab: 'photography',
            bookingsData: [],
            menuData: getInitialData(),
            notes: "تأكيد الحجز وتثبيت الموعد يتطلب دفع مبلغ عربون مقدماً.\nرسوم تذكرة دخول مكان التصوير (الأرضية) غير شاملة في الباقة وتكون على نفقة العميل.",
            db: null,
            appId: 'mrakby-studio-app',
            isEditModalOpen: false,
            editingItem: null,
            formImages: [],
            tempImageUrl: ''
        };

        const initFirebase = async () => {
            const app = initializeApp(firebaseConfig);
            const auth = getAuth(app);
            state.db = getFirestore(app);
            try {
                await signInAnonymously(auth);
                setupDBListeners();
            } catch(e) { console.error("Firebase connection error", e); }
        };

        function setupDBListeners() {
            // الاستماع للحجوزات
            const bookingsRef = collection(state.db, 'artifacts', state.appId, 'public', 'data', 'studio_bookings');
            onSnapshot(bookingsRef, (snap) => {
                state.bookingsData = snap.docs.map(d => ({id: d.id, ...d.data()}));
                if(state.isAuthenticated) renderApp();
            });

            // الاستماع للمنيو
            const menuRef = doc(state.db, 'artifacts', state.appId, 'public', 'data', 'studio_menu', 'latest');
            onSnapshot(menuRef, (docSnap) => {
                if (docSnap.exists()) {
                    const data = docSnap.data();
                    state.menuData = data.menuData || state.menuData;
                    state.notes = data.notes || state.notes;
                }
                if(state.isAuthenticated) renderApp();
            });
        }

        initFirebase();

        window.renderApp = () => {
            const root = document.getElementById('app-root');
            if (!state.isAuthenticated) {
                root.innerHTML = renderLogin();
            } else {
                root.innerHTML = `
                    <div class="flex h-screen overflow-hidden bg-slate-50">
                        ${renderSidebar()}
                        <div class="flex-1 flex flex-col h-screen overflow-hidden">
                            ${renderTopbar()}
                            <main class="flex-1 overflow-y-auto p-4 md:p-6 custom-scrollbar">
                                ${state.activeTab === 'dashboard' ? renderDashboard() : renderMenuManager()}
                            </main>
                        </div>
                    </div>
                    ${state.isEditModalOpen ? renderEditModal() : ''}
                `;
            }
            lucide.createIcons();
        };

        // استدعاء دالة الرسم فوراً لعرض شاشة تسجيل الدخول قبل الاتصال بفايربيس
        window.renderApp();

        // --- Login ---
        function renderLogin() {
            return `
            <div class="min-h-screen flex items-center justify-center p-4 bg-slate-900 relative overflow-hidden">
                <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=1200&auto=format&fit=crop')] bg-cover bg-center opacity-20"></div>
                <div class="bg-white p-8 rounded-3xl shadow-2xl w-full max-w-sm relative z-10 animate-in zoom-in-95">
                    <div class="w-16 h-16 bg-slate-900 rounded-full flex items-center justify-center mx-auto mb-4"><i data-lucide="shield-check" class="w-8 h-8 text-white"></i></div>
                    <h2 class="text-2xl font-black text-center mb-6">تسجيل دخول الإدارة</h2>
                    <form onsubmit="handleLogin(event)" class="space-y-4">
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-1">كلمة المرور</label>
                            <input type="password" name="password" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-left dir-ltr focus:ring-2 focus:ring-indigo-500 focus:outline-none" placeholder="••••••••">
                        </div>
                        <button type="submit" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-bold transition shadow-lg shadow-indigo-200">دخول للنظام</button>
                        <p id="login-error" class="text-red-500 text-xs font-bold text-center hidden">كلمة المرور غير صحيحة!</p>
                    </form>
                </div>
            </div>`;
        }

        window.handleLogin = (e) => {
            e.preventDefault();
            const pass = new FormData(e.target).get('password');
            if (pass === 'mrakby2026') {
                state.isAuthenticated = true;
                renderApp();
            } else {
                document.getElementById('login-error').classList.remove('hidden');
            }
        };

        // --- Layout ---
        function renderSidebar() {
            return `
            <aside class="w-64 bg-slate-900 text-white hidden md:flex flex-col shadow-xl z-20">
                <div class="p-6 border-b border-slate-800 flex items-center gap-3">
                    <div class="w-10 h-10 bg-indigo-500 rounded-xl flex items-center justify-center"><i data-lucide="aperture" class="w-6 h-6"></i></div>
                    <div><h1 class="font-black text-lg leading-none">Mrakby Studio</h1><p class="text-[10px] text-slate-400 uppercase tracking-widest mt-1">Admin Panel</p></div>
                </div>
                <nav class="flex-1 p-4 space-y-2">
                    <button onclick="switchTab('dashboard')" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl font-bold transition-all ${state.activeTab === 'dashboard' ? 'bg-indigo-600 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white'}"><i data-lucide="layout-dashboard" class="w-5 h-5"></i> الحجوزات والطلبات</button>
                    <button onclick="switchTab('menu')" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl font-bold transition-all ${state.activeTab === 'menu' ? 'bg-indigo-600 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white'}"><i data-lucide="menu-square" class="w-5 h-5"></i> إدارة المينيو</button>
                </nav>
                <div class="p-4 border-t border-slate-800">
                    <button onclick="location.reload()" class="w-full flex items-center gap-3 px-4 py-2 text-slate-400 hover:text-red-400 font-bold transition"><i data-lucide="log-out" class="w-5 h-5"></i> تسجيل الخروج</button>
                </div>
            </aside>`;
        }

        function renderTopbar() {
            return `
            <header class="bg-white border-b border-slate-200 px-4 py-3 flex items-center justify-between md:justify-end shadow-sm z-10">
                <div class="flex items-center gap-2 md:hidden">
                    <div class="w-8 h-8 bg-indigo-500 rounded-lg flex items-center justify-center text-white"><i data-lucide="aperture" class="w-5 h-5"></i></div>
                    <span class="font-black text-slate-800">Mrakby Studio</span>
                </div>
                <div class="flex gap-2 md:hidden">
                    <button onclick="switchTab('dashboard')" class="p-2 ${state.activeTab==='dashboard'?'text-indigo-600 bg-indigo-50':'text-slate-500'} rounded-lg"><i data-lucide="layout-dashboard" class="w-5 h-5"></i></button>
                    <button onclick="switchTab('menu')" class="p-2 ${state.activeTab==='menu'?'text-indigo-600 bg-indigo-50':'text-slate-500'} rounded-lg"><i data-lucide="menu-square" class="w-5 h-5"></i></button>
                </div>
                <div class="hidden md:flex items-center gap-3 bg-slate-100 px-3 py-1.5 rounded-full">
                    <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
                    <span class="text-xs font-bold text-slate-600">متصل بقاعدة البيانات</span>
                </div>
            </header>`;
        }

        window.switchTab = (tab) => { state.activeTab = tab; renderApp(); };

        // --- Dashboard / Bookings ---
        function renderDashboard() {
            const totalBookings = state.bookingsData.length;
            const totalRevenue = state.bookingsData.reduce((sum, b) => sum + (parseInt(String(b.packagePrice).replace(/,/g,'')) || 0), 0);
            
            return `
            <div class="mb-6 flex flex-col md:flex-row md:items-end justify-between gap-4">
                <div>
                    <h2 class="text-2xl font-black text-slate-800">إدارة الحجوزات</h2>
                    <p class="text-sm text-slate-500 mt-1 font-medium">تابع طلبات عملائك وأضف روابط الأرشيف (Drive) وتواصل معهم.</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex items-center gap-4">
                    <div class="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-full flex items-center justify-center"><i data-lucide="users" class="w-6 h-6"></i></div>
                    <div><p class="text-xs font-bold text-slate-500">إجمالي الحجوزات</p><p class="text-2xl font-black text-slate-800">${totalBookings}</p></div>
                </div>
                <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex items-center gap-4">
                    <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center"><i data-lucide="wallet" class="w-6 h-6"></i></div>
                    <div><p class="text-xs font-bold text-slate-500">المبيعات المتوقعة</p><p class="text-2xl font-black text-slate-800">${totalRevenue.toLocaleString()}</p></div>
                </div>
            </div>

            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden flex flex-col min-h-[400px]">
                <div class="overflow-x-auto custom-scrollbar flex-1">
                    <table class="w-full text-sm text-right min-w-[800px]">
                        <thead class="bg-slate-50 text-slate-600 font-bold border-b border-slate-200">
                            <tr>
                                <th class="p-4 whitespace-nowrap">الإيصال</th>
                                <th class="p-4 whitespace-nowrap">التاريخ</th>
                                <th class="p-4">العميل / العرسان</th>
                                <th class="p-4">الباقة والإضافات</th>
                                <th class="p-4 whitespace-nowrap">هاتف</th>
                                <th class="p-4 w-[300px]">رابط جوجل درايف (بوابة العميل)</th>
                                <th class="p-4 text-center whitespace-nowrap">إجراءات</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 font-medium">
                            ${state.bookingsData.length === 0 ? `<tr><td colspan="7" class="p-8 text-center text-slate-400">لا توجد حجوزات بعد.</td></tr>` : 
                            state.bookingsData.sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt)).map(b => {
                                const clientName = b.customerName || (b.groom ? `${b.groom} و ${b.bride}` : 'غير محدد');
                                const addonsTxt = b.addons?.length ? `<br><span class="text-[10px] text-emerald-600">+ ${b.addons.length} إضافات</span>` : '';
                                return `
                                <tr class="hover:bg-slate-50/50 transition-colors">
                                    <td class="p-4"><span class="bg-slate-100 text-slate-700 px-2 py-1 rounded text-xs font-bold font-mono">${b.receiptNumber}</span></td>
                                    <td class="p-4 whitespace-nowrap">${b.date}</td>
                                    <td class="p-4 font-bold text-slate-800">${clientName}</td>
                                    <td class="p-4"><span class="font-bold text-indigo-600">${b.packageName}</span>${addonsTxt}</td>
                                    <td class="p-4 font-mono text-slate-600" dir="ltr">${b.phone}</td>
                                    <td class="p-4">
                                        <div class="flex gap-2">
                                            <input id="drive-${b.id}" value="${b.driveLink||''}" placeholder="ألصق رابط صور العميل هنا..." class="flex-1 bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-xs focus:ring-2 focus:ring-indigo-500 focus:outline-none transition-all" dir="ltr">
                                            <button onclick="updateDriveLink('${b.id}')" class="bg-indigo-600 text-white px-3 py-2 rounded-lg text-xs font-bold hover:bg-indigo-700 transition shadow-sm">حفظ</button>
                                        </div>
                                    </td>
                                    <td class="p-4">
                                        <div class="flex items-center justify-center gap-1.5">
                                            <button onclick="sendWhatsAppToClient('${b.id}')" class="text-emerald-500 hover:text-emerald-700 hover:bg-emerald-50 p-2 rounded-lg transition" title="إرسال رابط البوابة للعميل عبر واتساب"><i data-lucide="message-circle" class="w-4 h-4"></i></button>
                                            <button onclick="editClientPassword('${b.id}')" class="text-amber-500 hover:text-amber-700 hover:bg-amber-50 p-2 rounded-lg transition" title="تعديل الرقم السري للعميل"><i data-lucide="key" class="w-4 h-4"></i></button>
                                            <button onclick="deleteBooking('${b.id}')" class="text-red-400 hover:text-red-600 hover:bg-red-50 p-2 rounded-lg transition" title="حذف الحجز نهائياً"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                                        </div>
                                    </td>
                                </tr>`;
                            }).join('')}
                        </tbody>
                    </table>
                </div>
            </div>`;
        }

        // إرسال الفاتورة والرابط الخاص بالعميل على رقمه المسجل
        window.sendWhatsAppToClient = (id) => {
            const b = state.bookingsData.find(x => x.id === id);
            if(!b) return;
            
            let phone = b.phone.trim();
            // تظبيط رقم الهاتف إذا كان يبدأ بـ 0 (مصر)
            if(phone.startsWith('0')) phone = '2' + phone; 

            // استنتاج الرابط الخاص بالمنيو بناءً على الدومين الحالي
            let currentPath = window.location.pathname;
            let menuPath = currentPath.replace('admin.html', '') || '/';
            if (!menuPath.endsWith('/')) menuPath += '/';
            
            const portalUrl = window.location.origin + menuPath + '?portal=' + b.receiptNumber;
            const clientName = b.customerName || b.groom;
            
            const msg = `مرحباً أ. ${clientName}،\nنشكرك على اختيارك (Mahmoud Elmrakby Studio) 📸\n\nتأكيداً على حجزك معنا:\nالباقة: *${b.packageName}*\nموعد المناسبة: ${b.date}\nرقم الإيصال: *${b.receiptNumber}*\n\nللدخول إلى ملفك الخاص لمتابعة حالة الحجز واستلام صورك بجودة عالية، يُرجى الدخول على الرابط التالي:\n${portalUrl}\n\nالرقم السري الخاص بك هو: ${b.password}\n\nنتمنى لك أوقاتاً سعيدة!`;
            
            window.open(`https://wa.me/${phone}?text=${encodeURIComponent(msg)}`, '_blank');
        };

        // تعديل الرقم السري للعميل
        window.editClientPassword = async (id) => {
            const b = state.bookingsData.find(x => x.id === id);
            if(!b) return;
            
            const clientName = b.customerName || b.groom;
            const newPass = prompt(`تعديل الرقم السري للعميل: ${clientName}\n\nالرقم السري الحالي هو: ${b.password}\n\nيرجى كتابة الرقم السري الجديد:`, b.password);
            
            if (newPass && newPass !== b.password) {
                await updateDoc(doc(state.db, 'artifacts', state.appId, 'public', 'data', 'studio_bookings', id), { password: newPass });
                alert("تم تحديث الرقم السري للعميل بنجاح!");
            }
        };

        window.updateDriveLink = async (id) => {
            const link = document.getElementById(`drive-${id}`).value;
            await updateDoc(doc(state.db, 'artifacts', state.appId, 'public', 'data', 'studio_bookings', id), { driveLink: link });
            alert("تم تحديث الرابط! سيراه العميل الآن في بوابته الخاصة.");
        };

        window.deleteBooking = async (id) => {
            if(confirm('هل أنت متأكد من حذف هذا الحجز نهائياً؟')) {
                await deleteDoc(doc(state.db, 'artifacts', state.appId, 'public', 'data', 'studio_bookings', id));
            }
        };

        // --- Menu Manager ---
        function renderMenuManager() {
            if(!state.menuData) return `<div class="p-10 text-center font-bold text-slate-500">جاري تحميل البيانات...</div>`;
            const tabs = [
                {id: 'photography', name: 'باقات الزفاف'}, {id: 'photoOnly', name: 'تصوير فقط'},
                {id: 'video', name: 'فيديو وسينما'}, {id: 'tableaus', name: 'التابلوهات'}, {id: 'gifts', name: 'الهدايا'}
            ];
            const items = state.menuData[state.menuTab] || [];

            return `
            <div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div><h2 class="text-2xl font-black text-slate-800">إدارة المينيو</h2><p class="text-sm text-slate-500 mt-1 font-medium">أضف، عدل أو احذف العروض والباقات لتظهر فوراً للعملاء.</p></div>
                <div class="flex gap-2">
                    <button onclick="openMenuModal('notes')" class="bg-amber-100 text-amber-700 hover:bg-amber-200 px-4 py-2.5 rounded-xl text-sm font-bold flex items-center gap-2 transition"><i data-lucide="file-text" class="w-4 h-4"></i> الملاحظات</button>
                    <button onclick="openMenuModal('promo')" class="bg-rose-100 text-rose-700 hover:bg-rose-200 px-4 py-2.5 rounded-xl text-sm font-bold flex items-center gap-2 transition"><i data-lucide="flame" class="w-4 h-4"></i> الإعلان الخاص</button>
                    <button onclick="openMenuModal(null)" class="bg-indigo-600 text-white hover:bg-indigo-700 px-4 py-2.5 rounded-xl text-sm font-bold flex items-center gap-2 transition shadow-lg shadow-indigo-200"><i data-lucide="plus" class="w-4 h-4"></i> إضافة عنصر</button>
                </div>
            </div>

            <div class="bg-white rounded-2xl border border-slate-200 p-2 mb-6 flex overflow-x-auto hide-scrollbar">
                ${tabs.map(t => `<button onclick="switchMenuTab('${t.id}')" class="flex-1 min-w-max px-6 py-2.5 rounded-xl text-sm font-bold transition-all ${state.menuTab === t.id ? 'bg-slate-900 text-white' : 'text-slate-500 hover:bg-slate-100'}">${t.name}</button>`).join('')}
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                ${items.map(item => `
                <div class="bg-white border border-slate-200 rounded-2xl p-4 flex flex-col hover:shadow-lg transition group relative">
                    <div class="absolute top-2 right-2 flex gap-1 z-10 opacity-100 md:opacity-0 group-hover:opacity-100 transition">
                        <button onclick="openMenuModal(${item.id})" class="p-1.5 bg-white shadow-sm border border-slate-100 rounded-lg text-indigo-600 hover:bg-indigo-50"><i data-lucide="pencil" class="w-4 h-4"></i></button>
                        <button onclick="deleteMenuItem(${item.id})" class="p-1.5 bg-white shadow-sm border border-slate-100 rounded-lg text-red-500 hover:bg-red-50"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                    </div>
                    <div class="h-32 bg-slate-100 rounded-xl mb-3 overflow-hidden">
                        ${item.images?.[0] ? `<img src="${item.images[0]}" class="w-full h-full object-cover">` : `<div class="w-full h-full flex items-center justify-center"><i data-lucide="image" class="w-8 h-8 text-slate-300"></i></div>`}
                    </div>
                    <h3 class="font-bold text-slate-800 mb-1 truncate">${item.name}</h3>
                    <p class="text-xs text-slate-500 mb-3 flex-1 line-clamp-2">${item.desc || (item.features?item.features[0]:'')}</p>
                    <div class="flex items-center justify-between border-t border-slate-100 pt-3">
                        <span class="font-black text-indigo-600">${item.price} <span class="text-[10px] text-slate-400">ج.م</span></span>
                        ${item.isPopular ? `<span class="bg-amber-100 text-amber-700 px-2 py-0.5 rounded text-[10px] font-bold"><i data-lucide="star" class="w-3 h-3 inline mb-0.5 fill-current"></i> الأكثر طلباً</span>` : ''}
                        ${item.isMini ? `<span class="bg-slate-100 text-slate-600 px-2 py-0.5 rounded text-[10px] font-bold">باقة مصغرة</span>` : ''}
                    </div>
                </div>`).join('')}
            </div>`;
        }

        window.switchMenuTab = (id) => { state.menuTab = id; renderApp(); };

        // --- Editing Menu Logic ---
        window.openMenuModal = (id) => {
            if (id === 'promo') { state.editingItem = state.menuData.promos[state.menuTab]; state.formImages = state.editingItem?.images || []; }
            else if (id === 'notes') { state.editingItem = { id: 'notes', desc: state.notes }; }
            else if (id) { state.editingItem = state.menuData[state.menuTab].find(i => i.id === id); state.formImages = state.editingItem?.images || []; }
            else { state.editingItem = null; state.formImages = []; }
            
            state.tempImageUrl = '';
            state.isEditModalOpen = true;
            renderApp();
        };

        window.closeMenuModal = () => { state.isEditModalOpen = false; renderApp(); };

        window.handleFileUpload = (e) => {
            const files = Array.from(e.target.files);
            files.forEach(file => {
                if (!file.type.startsWith('image/')) return;
                
                const reader = new FileReader();
                reader.onloadend = () => {
                    const img = new Image();
                    img.onload = () => {
                        // ضغط وتصغير الصورة قبل حفظها لتوفير مساحة قاعدة البيانات وتسريع المنيو
                        const canvas = document.createElement('canvas');
                        const MAX_WIDTH = 800; 
                        let width = img.width;
                        let height = img.height;
                        
                        if (width > MAX_WIDTH) {
                            height *= MAX_WIDTH / width;
                            width = MAX_WIDTH;
                        }
                        
                        canvas.width = width;
                        canvas.height = height;
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0, width, height);
                        
                        const dataUrl = canvas.toDataURL('image/jpeg', 0.75); // جودة 75%
                        state.formImages.push(dataUrl);
                        renderApp();
                    };
                    img.src = reader.result;
                };
                reader.readAsDataURL(file);
            });
            // إعادة تعيين الحقل ليسمح باختيار نفس الصورة مجدداً إن لزم الأمر
            e.target.value = '';
        };

        window.removeFormImage = (idx) => { state.formImages.splice(idx,1); renderApp(); };

        window.saveMenuItem = async (e) => {
            e.preventDefault();
            const fd = new FormData(e.target);
            const type = fd.get('type');
            
            if (type === 'notes') {
                await setDoc(doc(state.db, 'artifacts', state.appId, 'public', 'data', 'studio_menu', 'latest'), { notes: fd.get('desc') }, {merge: true});
                closeMenuModal(); return;
            }

            let newMenuData = JSON.parse(JSON.stringify(state.menuData)); // deep copy

            if (type === 'promo') {
                newMenuData.promos[state.menuTab] = {
                    isActive: fd.get('isActive') === 'on',
                    title: fd.get('title'), desc: fd.get('desc'),
                    price: fd.get('price'), oldPrice: fd.get('oldPrice'),
                    link: fd.get('link'), categoryName: fd.get('categoryName'),
                    images: state.formImages
                };
            } else {
                const newItem = {
                    id: state.editingItem ? state.editingItem.id : Date.now(),
                    name: fd.get('name'), price: fd.get('price'),
                    images: state.formImages,
                    isPopular: fd.get('isPopular') === 'on',
                    isMini: fd.get('isMini') === 'on'
                };
                if (['photography', 'video'].includes(state.menuTab)) {
                    newItem.features = fd.get('features').split('\n').filter(f => f.trim() !== '');
                } else {
                    newItem.desc = fd.get('desc');
                }

                if (state.editingItem) {
                    newMenuData[state.menuTab] = newMenuData[state.menuTab].map(i => i.id === state.editingItem.id ? newItem : i);
                } else {
                    newMenuData[state.menuTab].push(newItem);
                }
            }

            await setDoc(doc(state.db, 'artifacts', state.appId, 'public', 'data', 'studio_menu', 'latest'), { menuData: newMenuData }, {merge: true});
            closeMenuModal();
        };

        window.deleteMenuItem = async (id) => {
            if(confirm('متأكد من الحذف؟')) {
                let newMenuData = JSON.parse(JSON.stringify(state.menuData));
                newMenuData[state.menuTab] = newMenuData[state.menuTab].filter(i => i.id !== id);
                await setDoc(doc(state.db, 'artifacts', state.appId, 'public', 'data', 'studio_menu', 'latest'), { menuData: newMenuData }, {merge: true});
            }
        };

        function renderEditModal() {
            const item = state.editingItem;
            const type = item?.id === 'notes' ? 'notes' : (item?.id === 'promo' || item?.title ? 'promo' : 'item');
            
            return `
            <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm overflow-y-auto">
                <div class="bg-white rounded-[2rem] w-full max-w-lg shadow-2xl my-auto overflow-hidden animate-in zoom-in-95">
                    <div class="flex justify-between items-center p-5 border-b border-slate-100 bg-slate-50">
                        <h3 class="text-lg font-black text-slate-800">${type==='notes'?'الملاحظات':(type==='promo'?'الإعلان الخاص':(item?'تعديل عنصر':'إضافة جديد'))}</h3>
                        <button type="button" onclick="closeMenuModal()" class="p-2 hover:bg-slate-200 rounded-full text-slate-500 transition"><i data-lucide="x" class="w-5 h-5"></i></button>
                    </div>
                    <form onsubmit="saveMenuItem(event)" class="p-6 space-y-4 max-h-[75vh] overflow-y-auto custom-scrollbar">
                        <input type="hidden" name="type" value="${type}">
                        
                        ${type === 'notes' ? `
                            <div><label class="block text-sm font-bold mb-2">الملاحظات (سطر لكل ملاحظة)</label><textarea required rows="6" name="desc" class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 focus:ring-2 focus:ring-indigo-500">${item.desc}</textarea></div>
                        ` : type === 'promo' ? `
                            <div class="flex gap-2 p-3 bg-slate-50 rounded-xl border border-slate-200"><input type="checkbox" name="isActive" ${item?.isActive?'checked':''} class="w-5 h-5 accent-indigo-600"><label class="font-bold text-sm">تفعيل إعلان القسم الحالي</label></div>
                            <div class="grid grid-cols-2 gap-3">
                                <div><label class="block text-xs font-bold mb-1">العنوان</label><input required value="${item?.title||''}" name="title" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-sm"></div>
                                <div><label class="block text-xs font-bold mb-1">اسم القسم (مثل: الزفاف)</label><input required value="${item?.categoryName||''}" name="categoryName" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-sm"></div>
                            </div>
                            <div><label class="block text-xs font-bold mb-1">الوصف</label><textarea required name="desc" rows="2" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-sm">${item?.desc||''}</textarea></div>
                            <div class="grid grid-cols-2 gap-3">
                                <div><label class="block text-xs font-bold mb-1">السعر الجديد</label><input required value="${item?.price||''}" name="price" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-sm"></div>
                                <div><label class="block text-xs font-bold mb-1">السعر القديم</label><input required value="${item?.oldPrice||''}" name="oldPrice" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-sm"></div>
                            </div>
                            <div><label class="block text-xs font-bold mb-1">رابط الحجز (واتس اب)</label><input required value="${item?.link||''}" name="link" dir="ltr" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-sm"></div>
                            ${renderImageUploader()}
                        ` : `
                            <div><label class="block text-xs font-bold mb-1">الاسم</label><input required value="${item?.name||''}" name="name" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-sm"></div>
                            <div><label class="block text-xs font-bold mb-1">السعر</label><input required value="${item?.price||''}" name="price" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-sm"></div>
                            ${['photography','video'].includes(state.menuTab) ? `
                                <div><label class="block text-xs font-bold mb-1">المميزات (سطر لكل ميزة)</label><textarea required rows="4" name="features" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-sm">${item?.features?.join('\n')||''}</textarea></div>
                                <div class="flex gap-2 p-3 bg-slate-50 rounded-xl border border-slate-200"><input type="checkbox" name="isPopular" ${item?.isPopular?'checked':''} class="w-4 h-4 accent-amber-500"><label class="font-bold text-xs">الأكثر طلباً</label></div>
                            ` : `
                                <div><label class="block text-xs font-bold mb-1">الوصف</label><input required value="${item?.desc||''}" name="desc" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 text-sm"></div>
                                ${state.menuTab === 'photoOnly' ? `<div class="flex gap-2 p-3 bg-slate-50 rounded-xl border border-slate-200"><input type="checkbox" name="isMini" ${item?.isMini?'checked':''} class="w-4 h-4 accent-indigo-600"><label class="font-bold text-xs">باقة مصغرة (إضافة)</label></div>` : ''}
                            `}
                            ${['tableaus','gifts','photoOnly'].includes(state.menuTab) && item?.isMini ? '' : renderImageUploader()}
                        `}
                        
                        <div class="pt-4 flex gap-3 border-t border-slate-100">
                            <button type="submit" class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white py-3 rounded-xl font-bold transition shadow-lg">حفظ البيانات</button>
                            <button type="button" onclick="closeMenuModal()" class="px-6 bg-slate-200 hover:bg-slate-300 text-slate-800 rounded-xl font-bold transition">إلغاء</button>
                        </div>
                    </form>
                </div>
            </div>`;
        }

        function renderImageUploader() {
            return `
            <div>
                <label class="block text-xs font-bold mb-2">الصور (رفع من الجهاز)</label>
                <div class="flex flex-wrap gap-2 mb-3">
                    ${state.formImages.map((img, idx) => `
                        <div class="relative w-16 h-16 rounded-lg overflow-hidden border border-slate-200 group">
                            <img src="${img}" class="w-full h-full object-cover">
                            <button type="button" onclick="removeFormImage(${idx})" class="absolute inset-0 bg-red-500/80 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                        </div>
                    `).join('')}
                </div>
                <div class="flex mt-1">
                    <label class="w-full bg-slate-50 border-2 border-dashed border-slate-300 rounded-xl px-3 py-6 text-xs cursor-pointer flex flex-col items-center justify-center gap-2 hover:bg-indigo-50 hover:border-indigo-400 transition-all outline-none">
                        <i data-lucide="upload-cloud" class="w-7 h-7 text-indigo-500"></i>
                        <span class="font-bold text-slate-700 text-sm">اضغط هنا لاختيار ورفع الصور</span>
                        <span class="text-[10px] text-slate-500 font-normal">يتم ضغط الصور تلقائياً للحفاظ على سرعة عرض المنيو</span>
                        <input type="file" accept="image/*" multiple class="hidden" onchange="handleFileUpload(event)">
                    </label>
                </div>
            </div>`;
        }

        // دالة توفير البيانات المبدئية عند فراغ قاعدة البيانات
        function getInitialData() {
            return {
                promos: {
                    photography: { isActive: true, title: "🔥 باقة الأفراح الشاملة 🔥", desc: "خصم حصري على الباقة الماسية.", price: "12,000", oldPrice: "15,000", images: ["https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=1200&auto=format&fit=crop"], link: "https://wa.me/201201260040", categoryName: 'الزفاف' },
                    photoOnly: { isActive: true, title: "سيشن تصوير كابلز", desc: "احجز سيشن الخطوبة الآن واطبع صورك مجاناً!", price: "3,500", oldPrice: "4,500", images: ["https://images.unsplash.com/photo-1583939000140-6218d6e38cce?q=80&w=1200&auto=format&fit=crop"], link: "https://wa.me/201201260040", categoryName: 'التصوير' },
                    video: { isActive: true, title: "السينما 4K", desc: "فيلمك بأعلى جودة سينمائية وطيران درون مجاني.", price: "9,000", oldPrice: "11,000", images: ["https://images.unsplash.com/photo-1589087394126-9a2fc487e22f?q=80&w=1200&auto=format&fit=crop"], link: "https://wa.me/201201260040", categoryName: 'الفيديو' },
                    tableaus: { isActive: false }, gifts: { isActive: false }
                },
                photography: [], photoOnly: [], video: [], tableaus: [], gifts: []
            };
        }
    </script>
</body>
